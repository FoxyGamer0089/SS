#include<stdio.h>
#include<stdlib.h>
#include<unistd.h>

int main()
{
    int n,i=1,t;

    printf("Number of frames: ");
    scanf("%d",&n);

    while(i<=n)
    {
        printf("\nSending frame %d\n",i);

        t=rand()%2;

        if(t==0)
        {
            printf("Waiting for 1 second\n");
            sleep(1);

            printf("Missing acknowledgment %d\n",i);

            printf("Sending frame %d again\n",i);
        }

        printf("ACK received for frame %d\n",i);
        printf("Received frame %d successfully\n",i);

        i++;
    }

    printf("\nEnd of Stop and Wait Protocol\n");

    return 0;
}
